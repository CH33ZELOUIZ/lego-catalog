# Copy to .env and edit.
LEGO_CATALOG_PORT=3012
PORT=3012
FLASK_SECRET_KEY=replace-with-a-long-random-string
LEGO_DB_PATH=/data/lego_catalog.db
LEGO_OVERRIDE_PATH=/data/lego_overrides.json
LEGO_ASSET_DIR=/app/static/cache
# Optional mounted folder of local HEIC/JPG minifigure reference photos for the review page.
# If using docker-compose, uncomment the /photos volume and set this to /photos.
LEGO_PHOTO_REVIEW_DIR=
LEGO_USER_AGENT=LEGO Catalog self-hosted app
